# Caesar Cipher
text = input("Enter text: ").lower()
key = int(input("Enter key: "))
cipher = ""
for ch in text:
    if ch.isalpha():
        cipher += chr((ord(ch) - 97 + key) % 26 + 97)
    else:
        cipher += ch
print("Cipher Text:", cipher)
plain = ""
for ch in cipher:
    if ch.isalpha():
        plain += chr((ord(ch) - 97 - key) % 26 + 97)
    else:
        plain += ch
print("Plain Text:", plain)
